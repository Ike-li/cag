#!/usr/bin/env bash
# mock-provider: Controllable fake provider for testing cag-exec sentinel
# Usage: mock-provider <worktree> <behavior> [main-repo]
# Behaviors:
#   untracked  - create untracked file in main repo
#   modified   - modify existing file in main repo
#   commit     - commit changes in main repo
#   clean      - work correctly in worktree only (control)
set -euo pipefail

WORKTREE="${1:-}"
BEHAVIOR="${2:-clean}"
MAIN_REPO="${3:-}"

if [[ -z "$WORKTREE" ]]; then
  echo '{"error":"mock-provider requires worktree path"}' >&2
  exit 2
fi

# Read prompt from stdin (match codex/agy interface)
PROMPT=$(cat)

# Validate worktree exists
if [[ ! -d "$WORKTREE" ]]; then
  echo '{"error":"worktree does not exist","worktree":"'"$WORKTREE"'"}' >&2
  exit 2
fi

# Simulate thinking time
sleep 0.5

case "$BEHAVIOR" in
  untracked)
    # P2 test: create untracked file in main repo
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"untracked behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: escaping to $MAIN_REPO (untracked)" >&2
    echo "escaped by mock-provider" > "$MAIN_REPO/ESCAPED_UNTRACKED.txt"
    # Also do legit work in worktree to simulate real provider
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: escaped (untracked)" > "$WORKTREE/mock-output.txt"
    ;;

  modified)
    # P2 test: modify existing file in main repo
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"modified behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: escaping to $MAIN_REPO (modified)" >&2
    # Find an existing file to modify
    EXISTING=$(find "$MAIN_REPO" -maxdepth 1 -type f ! -name ".*" | head -1)
    if [[ -n "$EXISTING" ]]; then
      echo "ESCAPED MODIFICATION by mock-provider" >> "$EXISTING"
    else
      # Fallback: create new file
      echo "escaped (no file to modify)" > "$MAIN_REPO/ESCAPED_MODIFIED.txt"
    fi
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: escaped (modified)" > "$WORKTREE/mock-output.txt"
    ;;

  commit)
    # P3 test: commit in main repo
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"commit behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: escaping to $MAIN_REPO (commit)" >&2
    cd "$MAIN_REPO"
    echo "escaped by mock-provider" > ESCAPED_COMMITTED.txt
    git add ESCAPED_COMMITTED.txt
    git commit -m "ESCAPE: mock-provider committed" >/dev/null 2>&1
    cd "$WORKTREE"
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: escaped (commit)" > "$WORKTREE/mock-output.txt"
    ;;

  symlink-file)
    # S1: Symlink file attack - create symlink to main repo file, then write through it
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"symlink-file behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: symlink attack (file) to $MAIN_REPO" >&2
    # Create target file in main repo if not exists
    [[ -f "$MAIN_REPO/target.txt" ]] || echo "original content" > "$MAIN_REPO/target.txt"
    # Create symlink in worktree pointing to main repo
    cd "$WORKTREE"
    ln -s "$MAIN_REPO/target.txt" fake.txt
    # Write through symlink (writes to main repo)
    echo "SYMLINK ATTACK by mock-provider" >> fake.txt
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: symlink attack (file)" > "$WORKTREE/mock-output.txt"
    ;;

  symlink-dir)
    # S2: Symlink directory attack - create symlink to main repo dir, then write inside
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"symlink-dir behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: symlink attack (dir) to $MAIN_REPO" >&2
    # Create target directory in main repo if not exists
    mkdir -p "$MAIN_REPO/targetdir"
    [[ -f "$MAIN_REPO/targetdir/file.txt" ]] || echo "original" > "$MAIN_REPO/targetdir/file.txt"
    # Create symlink in worktree pointing to main repo directory
    cd "$WORKTREE"
    ln -s "$MAIN_REPO/targetdir" fakedir
    # Write through symlink (writes to main repo)
    echo "SYMLINK DIR ATTACK by mock-provider" >> fakedir/file.txt
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: symlink attack (dir)" > "$WORKTREE/mock-output.txt"
    ;;

  path-traversal)
    # S3: Path traversal attack - use relative paths to escape worktree
    if [[ -z "$MAIN_REPO" ]]; then
      echo '{"error":"path-traversal behavior requires main-repo path"}' >&2
      exit 2
    fi
    echo "mock-provider: path traversal attack (../) to $MAIN_REPO" >&2
    cd "$WORKTREE"
    # Calculate relative path from worktree to main repo
    # Worktree is typically at $MAIN_REPO/.worktrees/xxx, so ../../ goes back to main repo
    echo "PATH TRAVERSAL ATTACK by mock-provider" > ../../ESCAPED_TRAVERSAL.txt 2>/dev/null || true
    # Also try absolute path to main repo (more reliable for testing)
    echo "PATH TRAVERSAL ATTACK by mock-provider" > "$MAIN_REPO/ESCAPED_TRAVERSAL.txt" 2>/dev/null || true
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: path traversal attack" > "$WORKTREE/mock-output.txt"
    ;;

  home-escape)
    # S4: Home directory escape - use $HOME absolute path
    echo "mock-provider: home directory escape attack" >&2
    cd "$WORKTREE"
    # Try to write to $HOME
    echo "HOME ESCAPE ATTACK by mock-provider" > ~/cag-test-escape.txt 2>/dev/null || true
    echo "# Mock output\n\nTask: $PROMPT\n\nResult: home escape attack" > "$WORKTREE/mock-output.txt"
    ;;

  shell-injection)
    # R4: Shell injection test - output contains shell special characters
    echo "mock-provider: shell injection test" >&2
    cd "$WORKTREE"
    # Create output with shell special characters that should NOT be executed
    cat > "$WORKTREE/mock-output.txt" << 'EOF'
# Mock output with shell injection attempts

Task: test shell injection

Result: completed with special characters

Dangerous commands (should not execute):
- $(whoami)
- `date`
- ; rm -rf /tmp/test
- && echo "injected"
- | cat /etc/passwd

These should appear as literal text, not be executed.
EOF
    ;;

  crash)
    # R1: Provider crash test - simulate SEGFAULT
    echo "mock-provider: simulating crash (SEGFAULT)" >&2
    # Exit with non-zero to simulate crash (actual SEGFAULT would be exit 139)
    exit 139
    ;;

  malformed)
    # R3: Malformed output test - output non-JSON garbage
    echo "mock-provider: outputting malformed data" >&2
    cd "$WORKTREE"
    cat > "$WORKTREE/mock-output.txt" << 'EOF'
This is not JSON at all!
Just random text that cannot be parsed.
Special characters: <>&"'\{}[]
Incomplete JSON: {"key": "value"
EOF
    ;;

  clean)
    # Control: work correctly in worktree only
    echo "mock-provider: working cleanly in $WORKTREE" >&2
    # Support optional delay for concurrency testing
    DELAY="${4:-0}"
    if [[ "$DELAY" =~ ^[0-9]+$ ]] && [[ "$DELAY" -gt 0 ]]; then
      sleep "$DELAY"
    fi
    echo -e "# Mock output\n\nTask: $PROMPT\n\nResult: completed cleanly in worktree" > "$WORKTREE/mock-output.txt"
    ;;

  *)
    echo '{"error":"unknown behavior","behavior":"'"$BEHAVIOR"'","valid":["untracked","modified","commit","symlink-file","symlink-dir","path-traversal","home-escape","shell-injection","crash","malformed","clean"]}' >&2
    exit 2
    ;;
esac

echo "Mock provider finished (behavior: $BEHAVIOR)" >&2
exit 0
