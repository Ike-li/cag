#!/bin/zsh
# CAG execution choke point: worktree validation + env strip + provider exec + structured output
set -euo pipefail

DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && { DRY_RUN=true; shift; }

if [[ $# -lt 2 ]]; then
  echo '{"error":"usage: cag-exec [--dry-run] <codex|agy> <worktree-abs-path> [model] [reasoning-effort]  (prompt from stdin)"}' >&2
  exit 2
fi

PROVIDER=$1
WORKTREE=$2
MODEL=${3:-}           # Optional: model override (e.g., gpt-5.5, o3, gemini-2.0-flash-thinking)
REASONING=${4:-}       # Optional: reasoning effort (low, medium, high, xhigh)

# 0. Validate model availability (ChatGPT account limitations)
if [[ "$PROVIDER" == "codex" && -n "$MODEL" ]]; then
  case "$MODEL" in
    gpt-5.5)
      # Supported
      ;;
    gpt-4o|o3|o3-mini)
      echo '{"error":"model_not_supported","provider":"codex","model":"'"$MODEL"'","message":"Model '"'$MODEL'"' not supported with ChatGPT account. Use gpt-5.5 or leave MODEL empty.","worktree":"'"$WORKTREE"'"}' >&2
      exit 2
      ;;
    *)
      # Unknown model, let codex try (might be a future model)
      ;;
  esac
fi

# 1. Validate worktree
if [[ ! -d "$WORKTREE/.git" && ! -f "$WORKTREE/.git" ]]; then
  echo '{"error":"WORKTREE missing .git","worktree":"'"$WORKTREE"'"}' >&2
  exit 2
fi

# Worktree has .git as a file (points to main repo); main repo has .git as a directory
if [[ -d "$WORKTREE/.git" && ! -f "$WORKTREE/.git" ]]; then
  echo '{"error":"WORKTREE appears to be main repo (.git is directory, not file) — REJECTED","worktree":"'"$WORKTREE"'"}' >&2
  exit 2
fi

# 2. Read prompt from stdin
[[ -t 0 ]] && { echo '{"error":"stdin is a terminal — pipe the prompt via stdin"}' >&2; exit 2; }
PROMPT=$(cat)
if [[ -z "$PROMPT" ]] || [[ "$PROMPT" =~ '^[[:space:]]+$' ]]; then
  echo '{"error":"empty or whitespace-only prompt from stdin"}' >&2
  exit 2
fi
ARTIFACT="/tmp/cag-exec-raw-$$.txt"

# 3. Strip env + run provider
cd "$WORKTREE"

# Snapshot main repo state BEFORE provider runs, so the sentinel can tell a
# provider-caused escape from pre-existing uncommitted work in the main repo.
MAIN_COMMON=$(git rev-parse --git-common-dir 2>/dev/null)
MAIN_REPO=""
MAIN_BEFORE=""
if [[ -n "$MAIN_COMMON" ]]; then
  MAIN_REPO=$(cd "$(dirname "$MAIN_COMMON")" && pwd)
  [[ "$MAIN_REPO" == "$(pwd)" ]] && MAIN_REPO=""   # not a linked worktree; skip
  [[ -n "$MAIN_REPO" ]] && MAIN_BEFORE=$(git -C "$MAIN_REPO" status --porcelain 2>/dev/null)
fi

case "$PROVIDER" in
  codex)
    # Build command array to handle args properly
    CMD=(codex exec)
    [[ -n "$MODEL" ]] && CMD+=(--model "$MODEL")
    [[ -n "$REASONING" ]] && CMD+=(-c "model_reasoning_effort=$REASONING")
    # -s workspace-write + -C $WORKTREE: codex's native in-process sandbox pins
    # the writable root to the worktree and refuses writes outside it (verified:
    # rejects `echo > main_repo/file`). Replaces --dangerously-bypass-approvals-
    # and-sandbox, which disabled the sandbox entirely. Non-interactive under
    # `codex exec` — does not block on approval (verified). `-` reads prompt from
    # stdin. Unlike agy, codex has no nested-sandbox conflict and auths via
    # ~/.codex/auth.json (file, not Keychain), so the sandbox needs no holes.
    CMD+=(-s workspace-write -C "$WORKTREE" -)

    env -u CLAUDECODE -u CLAUDE_SESSION_ID -u CLAUDECODE_SESSION_ID \
        -u CLAUDE_CODE_ENTRYPOINT -u RUST_LOG -u RUST_BACKTRACE -u RUST_LIB_BACKTRACE \
        "${CMD[@]}" > "$ARTIFACT" 2>&1 <<< "$PROMPT" || EXIT_CODE=$?
    ;;
  agy)
    # Build command array to handle args properly
    CMD=(agy)
    [[ -n "$MODEL" ]] && CMD+=(--model "$MODEL")
    # Note: agy does not support reasoning effort parameter (verified 2026-06-06)
    # --add-dir pins agy's workspace to the worktree (without it agy may treat
    # ~/.gemini/.../scratch as workspace, search $HOME, and edit the main repo).
    # --sandbox replaces --dangerously-skip-permissions: still non-interactive
    # under --print (verified: does not block on confirmation) but enables
    # agy's terminal restrictions instead of auto-approving every tool call.
    CMD+=(--add-dir "$WORKTREE" --sandbox --print "$PROMPT" --print-timeout 9m)

    env -u CLAUDECODE -u CLAUDE_SESSION_ID -u CLAUDECODE_SESSION_ID -u CLAUDE_CODE_ENTRYPOINT \
        "${CMD[@]}" > "$ARTIFACT" 2>&1 || EXIT_CODE=$?
    ;;
  *)
    echo '{"error":"unknown provider","provider":"'"$PROVIDER"'"}' >&2
    exit 2
    ;;
esac
EXIT_CODE=${EXIT_CODE:-0}

# 3b. Jailbreak sentinel: a provider must only touch $WORKTREE. Compare the main
# repo's working tree against the BEFORE snapshot; any NEW change means the
# provider escaped its sandbox (observed with agy wandering to ~/.gemini/scratch,
# then editing the main repo). Pre-existing uncommitted work is ignored — only
# provider-introduced changes trip the sentinel. Refuse, do not commit, surface
# evidence.
if [[ -n "$MAIN_REPO" ]]; then
  MAIN_AFTER=$(git -C "$MAIN_REPO" status --porcelain 2>/dev/null)
  if [[ "$MAIN_AFTER" != "$MAIN_BEFORE" ]]; then
    ESC=$(comm -13 <(echo "$MAIN_BEFORE" | sort) <(echo "$MAIN_AFTER" | sort) | tr '\n' ';' | sed 's/"/\\"/g')
    echo '{"error":"SANDBOX ESCAPE — provider modified main repo, not the worktree","main_repo":"'"$MAIN_REPO"'","escaped_changes":"'"$ESC"'","worktree":"'"$WORKTREE"'","artifact":"'"$ARTIFACT"'"}' >&2
    exit 3
  fi
fi

# 4. Commit changes
CHANGED=false
if [[ -n "$(git status --porcelain)" ]]; then
  if [[ "$DRY_RUN" == "true" ]]; then
    CHANGED=true
  else
    # Guard: refuse to stage files larger than 50MB (accidental binary/dump generation)
    LARGE_FILES=$(find . -type f -size +50M 2>/dev/null | head -5)
    if [[ -n "$LARGE_FILES" ]]; then
      echo '{"error":"large files detected (>50MB) — refusing to commit","files":"'"$(echo "$LARGE_FILES" | tr '
' ' ')"'","worktree":"'"$WORKTREE"'"}' >&2
      exit 2
    fi
    git add -A
    COMMIT_ERR=$(git commit -q -m "cag: execution" 2>&1) && CHANGED=true || true
    if [[ "$CHANGED" != "true" ]]; then
      # Commit failed but changes staged (e.g., hook rejection)
      echo '{"error":"git commit failed but changes staged","reason":"'"$COMMIT_ERR"'","worktree":"'"$WORKTREE"'"}' >&2
      exit 2
    fi
  fi
fi

# 5. Output structured JSON
if [[ "$DRY_RUN" == "true" ]]; then
  if [[ "$CHANGED" == "true" ]]; then
    DIFF_STAT=$(git diff --shortstat HEAD 2>/dev/null | sed 's/^[[:space:]]*//')
    [[ -z "$DIFF_STAT" ]] && DIFF_STAT=$(git diff --staged --shortstat 2>/dev/null | sed 's/^[[:space:]]*//')
    [[ -z "$DIFF_STAT" ]] && DIFF_STAT="unknown"
  else
    DIFF_STAT="no changes"
  fi
  printf '{"exit_code":%d,"dry_run":true,"changed":%s,"diff_stat":"%s","artifact":"%s"}\n' \
    "$EXIT_CODE" "$CHANGED" "$DIFF_STAT" "$ARTIFACT"
else
  # diff_stat must agree with CHANGED: only read HEAD when this run produced the
  # commit (HEAD now points at it); otherwise HEAD is the pre-existing worktree
  # commit and its stat is unrelated to this execution.
  if [[ "$CHANGED" == "true" ]]; then
    DIFF_STAT=$(git show --shortstat HEAD 2>/dev/null | tail -1 | sed 's/^[[:space:]]*//')
    [[ -z "$DIFF_STAT" ]] && DIFF_STAT="unknown"
  else
    DIFF_STAT="no changes"
  fi
  printf '{"exit_code":%d,"changed":%s,"diff_stat":"%s","artifact":"%s"}\n' \
    "$EXIT_CODE" "$CHANGED" "$DIFF_STAT" "$ARTIFACT"
fi
